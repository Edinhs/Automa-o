APP_NAME=Stellantis Automation HUB
APP_ENV=operational
AUTH_DISABLED=true
DATABASE_URL=sqlite:///./data/automation_hub_dev.db
OPERATIONAL_DATABASE_URL=
DEVELOPER_DATABASE_URL=sqlite:///./data/developer/automation_hub_dev.db
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Local admin used when AUTH_DISABLED=true (defaults are fine). Set the password hash ONLY if you enable auth (AUTH_DISABLED=false).
# LOCAL_ADMIN_NETWORK_ID=TA25413
# LOCAL_ADMIN_EMAIL=TA25413@stellantis.com
# LOCAL_ADMIN_NAME=Ederson Siqueira dos Santos
# LOCAL_ADMIN_PASSWORD_HASH=   # gerar: python -c "import bcrypt; print(bcrypt.hashpw(b'SENHA', bcrypt.gensalt()).decode())"

PLAYGROUND_URL=https://genai.stellantis.com/
PLAYGROUND_BROWSER_CHANNEL=chromium
BROWSER_SESSION_PATH=./data/browser_session
OPERATIONAL_BROWSER_SESSION_PATH=
DEVELOPER_BROWSER_SESSION_PATH=./data/developer/browser_session
AGENT_SHARED_TOKEN=local-dev-agent-token
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_DEFAULT_TIMEOUT=30000
MANUAL_LOGIN_TIMEOUT_MINUTES=10
SCREENSHOTS_ERROR_PATH=./data/screenshots/errors
OPERATIONAL_SCREENSHOTS_ERROR_PATH=
DEVELOPER_SCREENSHOTS_ERROR_PATH=./data/developer/screenshots/errors

UPLOAD_BATCH_SIZE=5
DEFAULT_BATCH_INTERVAL_SECONDS=8
DEFAULT_MONITORING_TIMEOUT_MINUTES=30
DEFAULT_MONITOR_INTERVAL_SECONDS=30
SCHEDULE_POLL_INTERVAL_SECONDS=5
PROFILE_PHOTOS_PATH=./data/profile_photos
OPERATIONAL_TEMP_PATH=
OPERATIONAL_REPORTS_PATH=
OPERATIONAL_LOGS_PATH=
OPERATIONAL_PROFILE_PHOTOS_PATH=
DEVELOPER_TEMP_PATH=./data/developer/temp
DEVELOPER_REPORTS_PATH=./data/developer/reports
DEVELOPER_LOGS_PATH=./data/developer/logs
DEVELOPER_PROFILE_PHOTOS_PATH=./data/developer/profile_photos
PROFILE_PHOTO_MAX_BYTES=2097152

MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SCOPE=https://graph.microsoft.com/.default
MS_GRAPH_SENDER_USER=
MS_GRAPH_TEAMS_TEAM_ID=
MS_GRAPH_TEAMS_CHANNEL_ID=
MS_GRAPH_TEAMS_WEBHOOK_URL=
MS_GRAPH_TIMEOUT_SECONDS=20

# Pasta de entrega de relatorios (pickup externo / Power Automate Opcao 2): aponte para
# uma pasta (ex.: sincronizada ao OneDrive/SharePoint). Vazio = desligado.
# Todo relatorio gerado -- manual OU agendado -- e copiado para ca (+ um .json sidecar)
# assim que e persistido, para um fluxo do Power Automate entregar (Teams/email).
# REPORT_DELIVERY_PATH=./data/report_delivery
# DEVELOPER_REPORT_DELIVERY_PATH=./data/developer/report_delivery

# Logo exibida no topo do Adaptive Card do Teams. Precisa ser uma URL HTTPS *publica*
# (o Teams nao renderiza imagem local/base64 de forma confiavel). Vazio = sem imagem.
# REPORT_CARD_LOGO_URL=https://exemplo.com/stellantis-logo.png

# Card semanal do Teams (Relatorio Simplificado vira um convite + prova de valor):
# - Minutos de setup manual poupados por arquivo enviado (encontrar + subir ao workspace).
#   Vira as "horas economizadas" (semana + acumulado). 4 = padrao; suba se incluir controle de erro.
# REPORT_MINUTES_PER_FILE=4
# - URL do botao "Solicitar Acesso" no card (link da app Workflows do Teams). Vazio = sem botao.
# REPORT_CARD_ACCESS_URL=https://teams.microsoft.com/l/app/<appId-da-Workflows>
# - URL do botao "Abrir Playground" no card semanal. Vazio = usa PLAYGROUND_URL.
# REPORT_CARD_PLAYGROUND_URL=https://genai.stellantis.com/
